; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NetDex"
config/version="1.3"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"
config/developer_name="NoobNotFound"
config/copyright_notice="(c) VibeNoobNotFound"
config/repository_url="https://github.com/VibeNoobNotFound/net-dex"
config/releases_url="https://github.com/VibeNoobNotFound/net-dex/releases"

[autoload]

GameManager="*res://scripts/managers/GameManager.cs"
LobbyManager="*res://scripts/lobby/LobbyManager.cs"
MatchCoordinator="*res://scripts/game/MatchCoordinator.cs"
NetworkRpc="*res://scripts/network/NetworkRpc.cs"
NetworkManager="*res://scripts/network/NetworkManager.cs"
AiCoordinator="*res://scripts/ai/AiCoordinator.cs"
AudioManager="*res://scripts/managers/AudioManager.cs"
UpdateManager="*res://scripts/updates/UpdateManager.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/maximize_disabled=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="NetDex"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
