[gd_scene format=3 uid="uid://hostscreen"]

[ext_resource type="Script" path="res://scripts/ui/main/HostScreen.cs" id="1_host"]
[ext_resource type="Script" path="res://scripts/ui/common/MobileScrollContainer.cs" id="2_scroll"]

[node name="HostScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_host")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.04, 0.03, 0.03, 0.04)

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2_scroll")

[node name="MarginContainer" type="MarginContainer" parent="ScrollContainer"]
layout_mode = 2
