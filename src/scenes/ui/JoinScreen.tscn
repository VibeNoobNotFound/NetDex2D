[gd_scene format=3 uid="uid://joinscreen"]

[ext_resource type="Script" path="res://scripts/ui/main/JoinScreen.cs" id="1_join"]
[ext_resource type="Script" path="res://scripts/ui/common/MobileScrollContainer.cs" id="2_scroll"]

[node name="JoinScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_join")

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2_scroll")

[node name="MarginContainer" type="MarginContainer" parent="ScrollContainer"]
layout_mode = 2
